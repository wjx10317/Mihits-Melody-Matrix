# 文本自动检测；不强制统一 EOL，避免打乱已有 Windows 源码
* text=auto

# 二进制资源：不做文本 diff / 合并
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.ttf binary
*.otf binary
*.mp3 binary
*.ogg binary
*.wav binary
*.avi binary
*.mp4 binary
*.dll binary
*.lib binary
*.exe binary
*.pdb binary

# git archive 导出时排除大体积 / 非构建必需内容
assets/beatmaps/ export-ignore
tests/ export-ignore
scripts/ export-ignore
docs/ export-ignore

